---
const year = new Date().getFullYear();

const legalLinks = [
  { href: "/aviso-legal",            label: "Aviso legal" },
  { href: "/privacidad",             label: "Política de privacidad" },
  { href: "/divulgacion-afiliados",  label: "Divulgación de afiliados" },
  { href: "/contacto",               label: "Contacto" },
];
---

<footer class="bg-slate-900 text-slate-400 mt-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Bloque principal: marca + enlaces -->
    <div class="py-12 grid grid-cols-1 md:grid-cols-3 gap-10 border-b border-slate-800">

      <!-- Marca y descripción -->
      <div class="md:col-span-2">
        <a href="/" class="inline-flex items-baseline mb-4" aria-label="Inicio">
          <span class="font-display text-lg font-semibold text-white">Compara</span>
          <span class="font-display text-lg font-normal text-slate-400">Facturación</span>
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-sm">
          Análisis independientes y comparativas honestas de software de facturación
          para autónomos y pymes en España. Actualizados para Verifactu.
        </p>
      </div>

      <!-- Navegación legal -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">
          Legal
        </p>
        <nav class="flex flex-col gap-2.5" aria-label="Navegación legal">
          {legalLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-slate-400 hover:text-white transition-colors w-fit"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- Nota de transparencia + copyright -->
    <div class="py-8 space-y-4">
      <div class="border-l-2 border-slate-700 pl-4">
        <p class="text-xs text-slate-500 leading-relaxed">
          <span class="font-medium text-slate-400">Nota de transparencia:</span>{" "}
          Compara Facturación puede recibir una comisión cuando contratas productos
          a través de nuestros enlaces. Esto no influye en nuestras valoraciones.
        </p>
      </div>
      <p class="text-xs text-slate-600">
        © {year} Compara Facturación. Todos los derechos reservados.
      </p>
    </div>

  </div>
</footer>
