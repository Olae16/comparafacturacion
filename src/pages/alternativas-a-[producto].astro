---
import Layout from "../layouts/Layout.astro";
import productos from "../data/productos.json";

export function getStaticPaths() {
  const SLUGS_OBJETIVO = ["holded", "quipu", "sage", "billin", "anfix", "contasimple"];
  const PARES: [string, string][] = [
    ["quipu",        "billin"],
    ["quipu",        "holded"],
    ["quipu",        "anfix"],
    ["quipu",        "sage"],
    ["quipu",        "cuentica"],
    ["holded",       "sage"],
    ["holded",       "anfix"],
    ["billin",       "anfix"],
    ["billin",       "facturadirecta"],
    ["anfix",        "contasimple"],
    ["anfix",        "sage"],
    ["anfix",        "cuentica"],
    ["contasimple",  "facturadirecta"],
    ["contasimple",  "cuentica"],
  ];
  return SLUGS_OBJETIVO.map(slug => ({
    params:  { producto: slug },
    props:   { slugProducto: slug, pares: PARES, slugsObjetivo: SLUGS_OBJETIVO },
  }));
}

const { slugProducto, pares: PARES, slugsObjetivo: SLUGS_OBJETIVO } = Astro.props as {
  slugProducto:   string;
  pares:          [string, string][];
  slugsObjetivo:  string[];
};

const productoX   = productos.find(p => p.slug === slugProducto)!;
const alternativas = productos
  .filter(p => p.slug !== slugProducto)
  .sort((a, b) => b.puntuacion - a.puntuacion || a.slug.localeCompare(b.slug))
  .slice(0, 5);

function comparativaUrl(slugA: string, slugB: string): string | null {
  const par = PARES.find(([a, b]) =>
    (a === slugA && b === slugB) || (a === slugB && b === slugA)
  );
  if (!par) return null;
  return `/comparativa/${par[0]}-vs-${par[1]}`;
}

function sym(moneda: string) { return moneda === "USD" ? "$" : "€"; }
function precioLabel(p: typeof productoX) {
  return p.precios.desde === 0 ? "Gratis" : `${p.precios.desde}${sym(p.precios.moneda)}/mes`;
}

const otrasAlternativas = SLUGS_OBJETIVO.filter(s => s !== slugProducto);

const siteUrl    = "https://comparafacturacion.com";
const updateDate = new Date().toLocaleDateString("es-ES", { month: "long", year: "numeric" });

const pageTitle       = `Alternativas a ${productoX.nombre}: las ${alternativas.length} mejores opciones (2026)`;
const pageDescription = `¿Buscas alternativas a ${productoX.nombre}? Analizamos las ${alternativas.length} mejores opciones para 2026 con precios reales, pros y contras. Incluye comparativa directa.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio",    "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Programas", "item": `${siteUrl}/programas` },
        {
          "@type": "ListItem",
          "position": 3,
          "name": `Alternativas a ${productoX.nombre}`,
          "item": `${siteUrl}/alternativas-a-${slugProducto}`,
        },
      ],
    },
    {
      "@type": "ItemList",
      "name": pageTitle,
      "numberOfItems": alternativas.length,
      "itemListElement": alternativas.map((p, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": p.nombre,
        "url": `${siteUrl}/programa/${p.slug}`,
      })),
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <!-- ══ CABECERA -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[--color-primary-light]/60 to-transparent pointer-events-none"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 md:pt-24 md:pb-16">

      <nav class="text-xs text-slate-500 mb-6 flex items-center gap-1.5">
        <a href="/" class="hover:text-primary transition-colors">Inicio</a>
        <span>›</span>
        <a href="/programas" class="hover:text-primary transition-colors">Programas</a>
        <span>›</span>
        <span class="text-slate-700 font-medium">Alternativas a {productoX.nombre}</span>
      </nav>

      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Alternativas · 2026</p>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
          Las mejores alternativas<br class="hidden sm:block" /> a {productoX.nombre} en 2026
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed mb-5">
          {productoX.nombre} es {productoX.badge.toLowerCase()} con {productoX.puntuacion}/10.
          Algunos usuarios buscan alternativas porque {productoX.contras[0].toLowerCase()}.
          Aquí tienes las {alternativas.length} mejores opciones analizadas con datos reales y precios actualizados.
        </p>
        <span class="inline-flex items-center gap-1.5 text-xs text-slate-400 border border-slate-200 bg-white px-3 py-1.5 rounded-full">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Análisis actualizado en {updateDate}
        </span>
      </div>
    </div>
  </section>

  <!-- ══ RAZONES PARA CAMBIAR -->
  <div class="border-y border-slate-200 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">
        Razones más citadas para buscar alternativa a {productoX.nombre}
      </p>
      <div class="flex flex-wrap gap-2">
        {productoX.contras.slice(0, 3).map(contra => (
          <span class="text-xs bg-red-50 text-red-700 border border-red-100 px-3 py-1.5 rounded-lg">{contra}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- ══ ALTERNATIVAS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-slate-900 mb-2">
      Las {alternativas.length} mejores alternativas a {productoX.nombre}
    </h2>
    <p class="text-slate-500 text-sm mb-8">Ordenadas por valoración global · precios actualizados en {updateDate}.</p>

    <div class="flex flex-col gap-5">
      {alternativas.map((alt, i) => {
        const cmpUrl = comparativaUrl(slugProducto, alt.slug);
        return (
          <article class="bg-white rounded-2xl border border-slate-200 p-6 hover:shadow-md hover:border-primary/20 transition-all duration-200">
            <div class="flex flex-col sm:flex-row sm:items-start gap-5">

              <!-- Posición + Info -->
              <div class="flex items-start gap-4 flex-1 min-w-0">
                <span class="w-9 h-9 rounded-full bg-primary text-white text-sm font-bold flex items-center justify-center shrink-0">
                  {i + 1}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <h3 class="font-display text-xl font-semibold text-slate-900">{alt.nombre}</h3>
                    <span class="text-xs font-bold bg-amber-50 text-amber-700 border border-amber-100 px-2 py-0.5 rounded-lg">
                      ★ {alt.puntuacion}/10
                    </span>
                  </div>
                  <p class="text-xs text-slate-400 mb-3">{alt.badge} · {alt.empresa}</p>
                  <p class="text-sm text-slate-600 leading-relaxed mb-4">{alt.resumenCorto}</p>

                  <!-- Por qué es buena alternativa -->
                  <div class="bg-[--color-secondary-light] border border-secondary/20 rounded-xl px-4 py-3 mb-4">
                    <p class="text-xs font-semibold text-secondary mb-1">
                      Por qué es buena alternativa a {productoX.nombre}
                    </p>
                    <p class="text-sm text-slate-700 leading-relaxed">{alt.pros[0]}.</p>
                  </div>

                  <!-- Precio -->
                  <p class="text-sm text-slate-500">
                    <span class="font-semibold text-slate-900">Desde {precioLabel(alt)}</span>
                    {alt.precios.pruebaGratisDias > 0 && (
                      <span> · {alt.precios.pruebaGratisDias} días gratis</span>
                    )}
                  </p>
                </div>
              </div>

              <!-- CTAs -->
              <div class="flex sm:flex-col gap-2 sm:w-44 shrink-0">
                <a
                  href={`/programa/${alt.slug}`}
                  class="flex-1 sm:flex-none text-center text-sm font-semibold px-4 py-2.5 bg-primary text-white rounded-xl hover:bg-[--color-primary-dark] transition-colors"
                >
                  Ver análisis
                </a>
                {cmpUrl && (
                  <a
                    href={cmpUrl}
                    class="flex-1 sm:flex-none text-center text-xs font-semibold px-4 py-2.5 bg-slate-100 text-slate-700 rounded-xl hover:bg-slate-200 transition-colors leading-tight"
                  >
                    {productoX.nombre} vs {alt.nombre}
                  </a>
                )}
              </div>

            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- ══ MENCIÓN HONESTA A PRODUCTO X -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 md:p-8">
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-white border border-slate-200 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <h2 class="font-display text-lg font-semibold text-slate-900 mb-2">
            ¿Sigue siendo buena opción {productoX.nombre}?
          </h2>
          <p class="text-sm text-slate-600 leading-relaxed mb-3">
            Antes de cambiar, ten en cuenta que {productoX.nombre} sigue siendo la mejor opción si:
            <strong class="text-slate-800"> {productoX.idealPara.toLowerCase()}.</strong>
          </p>
          <a
            href={`/programa/${slugProducto}`}
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline"
          >
            Leer el análisis completo de {productoX.nombre}
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ OTRAS PÁGINAS DE ALTERNATIVAS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <h2 class="font-display text-xl font-semibold text-slate-900 mb-4">Otras páginas de alternativas</h2>
    <div class="flex flex-wrap gap-3">
      {otrasAlternativas.map(slug => {
        const prod = productos.find(p => p.slug === slug)!;
        return (
          <a
            href={`/alternativas-a-${slug}`}
            class="group bg-white border border-slate-200 rounded-xl px-4 py-3 hover:border-primary/40 hover:shadow-sm transition-all"
          >
            <p class="text-sm font-semibold text-slate-800 group-hover:text-primary transition-colors">
              Alternativas a {prod.nombre}
            </p>
          </a>
        );
      })}
      <a
        href="/comparativas"
        class="group bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 hover:bg-primary/10 transition-all"
      >
        <p class="text-sm font-semibold text-primary">Ver todas las comparativas →</p>
      </a>
    </div>
  </section>

</Layout>
