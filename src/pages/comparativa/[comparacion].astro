---
import Layout from "../../layouts/Layout.astro";
import productos from "../../data/productos.json";

// getStaticPaths debe ser autocontenida: define PARES dentro y la pasa como prop
export function getStaticPaths() {
  const PARES: [string, string][] = [
    ["quipu",        "billin"],
    ["quipu",        "holded"],
    ["quipu",        "anfix"],
    ["quipu",        "sage"],
    ["quipu",        "cuentica"],
    ["holded",       "sage"],
    ["holded",       "anfix"],
    ["billin",       "anfix"],
    ["billin",       "facturadirecta"],
    ["anfix",        "contasimple"],
    ["anfix",        "sage"],
    ["anfix",        "cuentica"],
    ["contasimple",  "facturadirecta"],
    ["contasimple",  "cuentica"],
  ];
  return PARES.map(([a, b]) => ({
    params: { comparacion: `${a}-vs-${b}` },
    props: { slugA: a, slugB: b, pares: PARES },
  }));
}

const { slugA, slugB, pares: PARES } = Astro.props as {
  slugA: string;
  slugB: string;
  pares: [string, string][];
};

const pA = productos.find(p => p.slug === slugA)!;
const pB = productos.find(p => p.slug === slugB)!;

const updateDate = new Date().toLocaleDateString("es-ES", { month: "long", year: "numeric" });

function sym(moneda: string) { return moneda === "USD" ? "$" : "€"; }
function precioLabel(p: typeof pA) {
  return p.precios.desde === 0 ? "Gratis" : `${p.precios.desde}${sym(p.precios.moneda)}/mes`;
}

// ── Filas de la tabla comparativa ───────────────────────────────────────────
const filasCaracteristicas = [
  { key: "verifactu",            label: "Verifactu" },
  { key: "ticketbai",            label: "TicketBAI" },
  { key: "facturaeFace",         label: "Factura-e / FACe" },
  { key: "conciliacionBancaria", label: "Conciliación bancaria" },
  { key: "ocrGastos",            label: "OCR de gastos" },
  { key: "contabilidadCompleta", label: "Contabilidad completa" },
  { key: "crm",                  label: "CRM" },
  { key: "gestionProyectos",     label: "Gestión de proyectos" },
  { key: "inventario",           label: "Inventario" },
  { key: "multiusuario",         label: "Multi-usuario" },
  { key: "multiempresa",         label: "Multi-empresa" },
  { key: "appIos",               label: "App iOS" },
  { key: "appAndroid",           label: "App Android" },
  { key: "integracionShopify",   label: "Shopify" },
  { key: "integracionStripe",    label: "Stripe" },
];

const carA = pA.caracteristicas as Record<string, boolean>;
const carB = pB.caracteristicas as Record<string, boolean>;

// ── Veredicto basado en campos idealPara / noRecomendadoSi ──────────────────
// (texto generado desde datos reales, sin inventar nada)
const siteUrl  = "https://comparafacturacion.com";
const pageSlug = `${slugA}-vs-${slugB}`;

// ── SEO ──────────────────────────────────────────────────────────────────────
const pageTitle       = `${pA.nombre} vs ${pB.nombre}: comparativa y cuál elegir (2026)`;
const pageDescription = `Comparamos ${pA.nombre} y ${pB.nombre} cara a cara: precios, características, pros y contras. Descubre cuál es mejor para tu negocio en 2026.`;

// ── JSON-LD ───────────────────────────────────────────────────────────────────
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio",       "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Comparativas", "item": `${siteUrl}/comparativas` },
        { "@type": "ListItem", "position": 3, "name": `${pA.nombre} vs ${pB.nombre}`, "item": `${siteUrl}/comparativa/${pageSlug}` },
      ],
    },
    {
      "@type": "WebPage",
      "name": pageTitle,
      "description": pageDescription,
      "url": `${siteUrl}/comparativa/${pageSlug}`,
    },
  ],
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">

    <!-- ── MIGA DE PAN -->
    <nav class="text-xs text-slate-500 mb-8 flex items-center gap-1.5">
      <a href="/" class="hover:text-primary transition-colors">Inicio</a>
      <span>›</span>
      <a href="/comparativas" class="hover:text-primary transition-colors">Comparativas</a>
      <span>›</span>
      <span class="text-slate-700 font-medium">{pA.nombre} vs {pB.nombre}</span>
    </nav>

    <!-- ── CABECERA -->
    <div class="mb-12">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-[--color-primary-light] text-primary border border-primary/20">
          Comparativa 2026
        </span>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        {pA.nombre} vs {pB.nombre}
      </h1>
      <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mb-4">
        Analizamos {pA.nombre} y {pB.nombre} cara a cara para ayudarte a elegir el software de
        facturación que mejor se adapta a tu negocio.
      </p>
      <span class="flex items-center gap-1.5 text-xs text-slate-400 border border-slate-200 bg-white px-3 py-1.5 rounded-full w-fit">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Análisis actualizado en {updateDate}
      </span>
    </div>

    <!-- ── RESUMEN RÁPIDO (2 tarjetas lado a lado) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-14">
      {[pA, pB].map((p) => (
        <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col gap-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <span class="text-xs font-semibold text-primary bg-[--color-primary-light] px-2.5 py-1 rounded-full">{p.badge}</span>
              <h2 class="font-display text-2xl font-bold text-slate-900 mt-2">{p.nombre}</h2>
              <p class="text-xs text-slate-400">{p.empresa}</p>
            </div>
            <div class="flex items-center gap-1 bg-amber-50 border border-amber-100 px-2.5 py-1.5 rounded-xl shrink-0">
              <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span class="text-xs font-bold text-amber-700">{p.puntuacion}</span>
              <span class="text-xs text-amber-500">/10</span>
            </div>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed flex-1">{p.resumenCorto}</p>
          <div class="pt-3 border-t border-slate-100 flex items-center justify-between">
            <div>
              <span class="text-xs text-slate-400">Desde</span>
              <p class="font-display text-xl font-semibold text-slate-900">{precioLabel(p)}</p>
            </div>
            <a href={`/programa/${p.slug}`} class="text-xs font-semibold text-primary hover:text-primary flex items-center gap-1">
              Ver reseña completa →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- ── TABLA COMPARATIVA CARA A CARA -->
    <section class="mb-14">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-slate-900 mb-6">
        Comparativa cara a cara
      </h2>

      <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left px-5 py-4 font-semibold text-slate-500 w-1/2 md:w-2/5">Característica</th>
              <th class="px-4 py-4 text-center font-display font-bold text-slate-900">{pA.nombre}</th>
              <th class="px-4 py-4 text-center font-display font-bold text-slate-900">{pB.nombre}</th>
            </tr>
          </thead>
          <tbody>
            <!-- Precio -->
            <tr class="border-b border-slate-100 bg-slate-50/50">
              <td colspan="3" class="px-5 py-2 text-xs font-semibold uppercase tracking-wider text-slate-400">Precio</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-5 py-3 text-slate-700">Precio desde</td>
              <td class="px-4 py-3 text-center font-semibold text-slate-900">{precioLabel(pA)}</td>
              <td class="px-4 py-3 text-center font-semibold text-slate-900">{precioLabel(pB)}</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-5 py-3 text-slate-700">Prueba gratis</td>
              <td class="px-4 py-3 text-center font-semibold text-secondary">{pA.precios.pruebaGratisDias} días</td>
              <td class="px-4 py-3 text-center font-semibold text-secondary">{pB.precios.pruebaGratisDias} días</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-5 py-3 text-slate-700">Puntuación</td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center gap-1 bg-amber-50 px-2 py-0.5 rounded-lg text-amber-700 font-bold text-xs">
                  ★ {pA.puntuacion}/10
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center gap-1 bg-amber-50 px-2 py-0.5 rounded-lg text-amber-700 font-bold text-xs">
                  ★ {pB.puntuacion}/10
                </span>
              </td>
            </tr>

            <!-- Características -->
            <tr class="border-b border-slate-100 bg-slate-50/50">
              <td colspan="3" class="px-5 py-2 text-xs font-semibold uppercase tracking-wider text-slate-400">Características</td>
            </tr>
            {filasCaracteristicas.map((fila, i) => (
              <tr class={`border-b border-slate-100 ${i % 2 === 0 ? "" : "bg-slate-50/30"}`}>
                <td class="px-5 py-3 text-slate-700">{fila.label}</td>
                <td class="px-4 py-3 text-center">
                  {carA[fila.key] ? (
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[--color-secondary-light]">
                      <svg class="w-3.5 h-3.5 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                    </span>
                  ) : (
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-slate-100">
                      <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </span>
                  )}
                </td>
                <td class="px-4 py-3 text-center">
                  {carB[fila.key] ? (
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[--color-secondary-light]">
                      <svg class="w-3.5 h-3.5 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                    </span>
                  ) : (
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-slate-100">
                      <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ── PROS DE CADA UNO -->
    <section class="mb-14">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-slate-900 mb-6">
        Lo mejor de cada uno
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[pA, pB].map((p) => (
          <div class="bg-[--color-secondary-light] border border-secondary/20 rounded-2xl p-6">
            <h3 class="font-display text-lg font-semibold text-secondary mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
              </svg>
              Puntos fuertes de {p.nombre}
            </h3>
            <ul class="flex flex-col gap-3">
              {p.pros.map((pro) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-secondary shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {pro}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- ── VEREDICTO -->
    <section class="mb-14">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-slate-900 mb-6">
        ¿Cuál elegir?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        {[pA, pB].map((p) => (
          <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col gap-4">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 bg-[--color-primary-light] rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/>
                </svg>
              </div>
              <h3 class="font-display font-semibold text-slate-900">Elige {p.nombre} si…</h3>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{p.idealPara}</p>
            <div class="flex items-start gap-2 bg-amber-50 rounded-xl p-3">
              <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
              </svg>
              <p class="text-xs text-amber-700 leading-relaxed"><strong>No lo elijas si:</strong> {p.noRecomendadoSi}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Párrafo de veredicto general -->
      <div class="bg-[--color-primary-light] border border-primary/20 rounded-2xl p-6">
        <p class="text-sm text-slate-700 leading-relaxed">
          <strong class="text-slate-900">{pA.nombre}</strong> es la mejor opción si tu prioridad es
          {pA.targetPrincipal.toLowerCase()} y valoras {pA.badge.toLowerCase()}.
          <strong class="text-slate-900">{pB.nombre}</strong>, en cambio, encaja mejor con
          {pB.targetPrincipal.toLowerCase()} y destaca como {pB.badge.toLowerCase()}.
          Ambos cumplen la normativa Verifactu{carA["verifactu"] && carB["verifactu"] ? " y son válidos para facturar en España" : carA["verifactu"] ? ` (${pA.nombre} sí; ${pB.nombre} necesita integración adicional)` : ` (${pB.nombre} sí; ${pA.nombre} necesita integración adicional)`}.
        </p>
      </div>
    </section>

    <!-- ── CTAs DOBLES -->
    <section class="mb-14">
      <h2 class="font-display text-2xl font-bold text-slate-900 mb-6">Pruébalos gratis</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[pA, pB].map((p) => (
          <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col gap-4">
            <div>
              <p class="font-display text-lg font-semibold text-slate-900">{p.nombre}</p>
              <p class="text-sm text-slate-500">{p.precios.pruebaGratisDias} días gratis · Sin tarjeta</p>
            </div>
            <a
              href={p.afiliacion.linkAfiliado}
              target="_blank"
              rel="sponsored nofollow"
              class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-secondary text-white font-semibold rounded-xl hover:bg-[--color-secondary-dark] transition-colors text-sm"
            >
              Probar {p.nombre} gratis
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </a>
            <a href={`/programa/${p.slug}`} class="text-xs text-center text-slate-400 hover:text-primary transition-colors">
              Leer reseña completa de {p.nombre} →
            </a>
            {p.afiliacion.tienePrograma && (
              <p class="text-xs text-center text-slate-400">Enlace de afiliado · sin coste adicional para ti</p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- ── OTRAS COMPARATIVAS RELACIONADAS -->
    <section>
      <h2 class="font-display text-xl font-bold text-slate-900 mb-4">Otras comparativas</h2>
      <div class="flex flex-wrap gap-2">
        {PARES
          .filter(([a, b]) => !(a === slugA && b === slugB))
          .filter(([a, b]) => a === slugA || b === slugA || a === slugB || b === slugB)
          .slice(0, 6)
          .map(([a, b]) => {
            const nA = productos.find(p => p.slug === a)!.nombre;
            const nB = productos.find(p => p.slug === b)!.nombre;
            return (
              <a
                href={`/comparativa/${a}-vs-${b}`}
                class="text-sm bg-white border border-slate-200 text-slate-600 hover:border-primary/40 hover:text-primary px-4 py-2 rounded-xl transition-colors"
              >
                {nA} vs {nB}
              </a>
            );
          })
        }
        <a href="/comparativas" class="text-sm bg-[--color-primary-light] border border-primary/20 text-primary px-4 py-2 rounded-xl transition-colors font-medium">
          Ver todas →
        </a>
      </div>
    </section>

  </div>
</Layout>
