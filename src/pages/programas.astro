---
import Layout from "../layouts/Layout.astro";
import productos from "../data/productos.json";
import ExploreCategories from "../components/ExploreCategories.astro";

function getBadgeClass(badge: string) {
  if (badge.toLowerCase().includes("precio") || badge.toLowerCase().includes("gratuito")) return "bg-secondary-light text-secondary";
  if (badge.toLowerCase().includes("pyme") || badge.toLowerCase().includes("ecosistema") || badge.toLowerCase().includes("internacional") || badge.toLowerCase().includes("consolidada")) return "bg-amber-50 text-amber-700";
  return "bg-primary-light text-primary";
}

function getTopTags(car: Record<string, unknown>) {
  const candidatos = [
    { key: "verifactu",            label: "Verifactu" },
    { key: "contabilidadCompleta", label: "Contabilidad" },
    { key: "crm",                  label: "CRM" },
    { key: "inventario",           label: "Inventario" },
    { key: "conciliacionBancaria", label: "Conciliación bancaria" },
    { key: "ocrGastos",            label: "OCR gastos" },
    { key: "multiempresa",         label: "Multi-empresa" },
    { key: "appMovil",             label: "App móvil" },
  ];
  return candidatos.filter(t => !!car[t.key]).map(t => t.label).slice(0, 3);
}

const ordenados = [...productos].sort((a, b) => b.puntuacion - a.puntuacion);

const siteUrl = "https://comparafacturacion.com";
const programasJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Compara Facturación",
      "url": siteUrl
    },
    {
      "@type": "Organization",
      "name": "Compara Facturación",
      "url": siteUrl,
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@comparafacturacion.com",
        "contactType": "customer support"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Programas de facturación",
          "item": `${siteUrl}/programas`
        }
      ]
    }
  ]
};
---

<Layout
  title="Mejores programas de facturación para autónomos y pymes 2026"
  description="Compara los 10 mejores programas de facturación para autónomos y pymes en España. Precios reales, análisis independientes y compatibilidad con Verifactu."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(programasJsonLd)} />

  <!-- ══════════════════════════════════════════ CABECERA -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[--color-primary-light]/60 to-transparent pointer-events-none"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 md:pt-24 md:pb-16">

      <nav class="text-xs text-slate-500 mb-6 flex items-center gap-1.5">
        <a href="/" class="hover:text-primary transition-colors">Inicio</a>
        <span>›</span>
        <span class="text-slate-700 font-medium">Programas de facturación</span>
      </nav>

      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Catálogo completo</p>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
          Mejores programas de<br />facturación en España
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
          {productos.length} programas analizados con datos reales de precios, características y compatibilidad
          con Verifactu. Ordenados por puntuación.
        </p>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════ FILTROS / STATS -->
  <div class="border-y border-slate-200 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap items-center gap-6 text-sm text-slate-500">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-secondary shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        <span>{productos.length} programas analizados</span>
      </div>
      <div class="hidden sm:block w-px h-4 bg-slate-200"></div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-secondary shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        <span>{productos.filter(p => p.caracteristicas.verifactu).length} compatibles con Verifactu</span>
      </div>
      <div class="hidden sm:block w-px h-4 bg-slate-200"></div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-secondary shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        <span>Actualizado en {new Date().toLocaleDateString("es-ES", { month: "long", year: "numeric" })}</span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════ EXPLORA POR CATEGORÍA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Busca por tipo de negocio</p>
    <ExploreCategories />
  </section>

  <!-- ══════════════════════════════════════════ GRID DE TARJETAS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      {ordenados.map((p, i) => (
        <article class="bg-white rounded-2xl border border-slate-200 p-6 flex flex-col hover:shadow-lg hover:border-primary/20 transition-all duration-200 relative">

          {i === 0 && (
            <div class="absolute -top-3 left-5">
              <span class="inline-flex items-center gap-1 bg-secondary text-white text-xs font-semibold px-3 py-1 rounded-full shadow-sm">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                Mejor valorado
              </span>
            </div>
          )}

          <!-- Cabecera -->
          <div class="flex items-start justify-between gap-3 mb-4">
            <div>
              <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full ${getBadgeClass(p.badge)} mb-2`}>
                {p.badge}
              </span>
              <h2 class="font-display text-xl font-semibold text-slate-900">{p.nombre}</h2>
              <p class="text-xs text-slate-400 mt-0.5">{p.empresa}</p>
            </div>
            <div class="flex items-center gap-1 shrink-0 bg-amber-50 border border-amber-100 px-2.5 py-1.5 rounded-xl">
              <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span class="text-xs font-bold text-amber-700">{p.puntuacion}</span>
              <span class="text-xs text-amber-500">/10</span>
            </div>
          </div>

          <!-- Resumen -->
          <p class="text-sm text-slate-600 leading-relaxed mb-4 flex-1">{p.resumenCorto}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5 mb-5">
            {getTopTags(p.caracteristicas).map((tag) => (
              <span class="text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-md font-medium">{tag}</span>
            ))}
            {!p.caracteristicas["verifactu"] && (
              <span class="text-xs bg-red-50 text-red-600 px-2.5 py-1 rounded-md font-medium border border-red-100">Sin Verifactu</span>
            )}
          </div>

          <!-- Precio + CTA -->
          <div class="flex items-center justify-between pt-4 border-t border-slate-100">
            <div>
              <span class="text-xs text-slate-400">Desde</span>
              <p class="font-display text-xl font-semibold text-slate-900">
                {p.precios.desde === 0 ? "Gratis" : `${p.precios.desde}${p.precios.moneda === "USD" ? "$" : "€"}`}
                {p.precios.desde > 0 && <span class="text-sm font-normal text-slate-500">/mes</span>}
              </p>
            </div>
            <a
              href={`/programa/${p.slug}`}
              class="text-sm font-semibold text-primary hover:text-primary-dark transition-colors flex items-center gap-1"
            >
              Ver análisis
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </a>
          </div>

        </article>
      ))}

    </div>
  </section>

  <!-- ══════════════════════════════════════════ CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="bg-primary rounded-3xl px-8 py-14 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
      <div class="relative">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
          ¿No sabes cuál elegir?
        </h2>
        <p class="text-blue-200 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
          Lee los análisis completos de cada programa: precios reales, pros, contras y para quién es ideal.
        </p>
        <a
          href="/programa/quipu"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-primary font-semibold rounded-xl hover:bg-blue-50 transition-colors shadow-lg"
        >
          Empezar por el mejor valorado
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>
